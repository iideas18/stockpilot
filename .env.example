# ═══════════════════════════════════════════════════════════════
# StockPilot Environment Configuration
# Copy to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════════

# === LLM Providers ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# === Azure OpenAI (optional) ===
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01

# === Financial Data ===
FINANCIAL_DATASETS_API_KEY=

# === Data Sources ===
ALPHA_VANTAGE_API_KEY=
TUSHARE_TOKEN=
# AKShare: no API key needed (free)
# yfinance: no API key needed (free)

# === Database ===
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/stockpilot
# Fallback to SQLite if MySQL unavailable:
# DATABASE_URL=sqlite:///stockpilot.db
REDIS_URL=redis://localhost:6379/0

# === News & Social ===
# Optional: override the default news platforms used by NewsAggregator()
# Precedence: explicit NewsAggregator(platforms=[...]) > STOCKPILOT_NEWS_PLATFORMS > NEWS_PLATFORMS > config/settings.yaml
# Default from config/settings.yaml: weibo,douyin,zhihu,reddit,hackernews
# Format: comma-separated list, not JSON
# Supported keys: weibo, zhihu, douyin, hackernews, reddit_finance
# Alias supported: reddit -> reddit_finance
STOCKPILOT_NEWS_PLATFORMS=weibo,douyin,zhihu,reddit,hackernews
# NEWS_PLATFORMS=weibo,douyin,zhihu,reddit,hackernews
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stockpilot/0.1.0

# === Notifications ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DINGTALK_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
WECHAT_WORK_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_RECIPIENTS=

# === Trading (Optional) ===
# BROKER_TYPE=gf  # gf, ht, yh, etc.
# BROKER_USER=
# BROKER_PASSWORD=

# === Application ===
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
